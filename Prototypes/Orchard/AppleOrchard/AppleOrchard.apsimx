            {
              "$type": "Models.PMF.Plant, Models",
              "Name": "Slurp",
              "ResourceName": "Slurp",
              "Children": [],
              "Enabled": true,
              "ReadOnly": false
            },
            {
              "$type": "Models.Report, Models",
              "VariableNames": [
                "[Clock].Today as Date",
                "[Clock].Today.DayOfYear as DayOfYear",
                "",
                "// Water outputs",
                "[Weather].Rain as Rainfall",
                "[Irrigation].IrrigationApplied as Irrigation",
                "[MicroClimate].PrecipitationInterception as PrecipitationInterception",
                "[Soil].SoilWater.Eo as Eo",
                "[Soil].SoilWater.Es as Evaporation",
                "[Slurp].Leaf.Transpiration as Transpiration",
                "[Soil].SoilWater.Drainage as Drainage",
                "[Soil].SoilWater.Runoff as Runoff",
                "sum([Soil].SoilWater.LateralOutflow) as LateralFlow",
                "[Soil].SoilWater.pond as PondedWater",
                "sum([Soil].Water.MM) as TotalSWC",
                "sum([Soil].Physical.SATmm) as TotalSAT",
                "sum([Soil].Physical.DULmm) as TotalDUL",
                "sum([Soil].Physical.LL15mm) as TotalLL15",
                "[Soil].Water.Volumetric[1] as TopLayerSWC",
                "[Soil].Physical.DUL[1] as TopLayerDUL",
                "[Soil].Physical.LL15[1] as TopLayerLL15",
                "",
                "// Nitrogen outputs",
                "[Fertiliser].NitrogenApplied as FertiliserN",
                "([Fertiliser].NitrogenApplied*0.0) as FixedN",
                "sum([Soil].Nutrient.DenitrifiedN) as DenitrifiedN",
                "([Soil].SoilWater.LeachUrea + [Soil].SoilWater.LeachNH4 + [Soil].SoilWater.LeachNO3) as LeachedN",
                "(-1*[Slurp].Root.NUptake) as UptakeN",
                "(sum([Soil].Nutrient.MineralisedN) + sum([Soil].Nutrient.MineralisedNSurfaceResidue)) as NetMineralisedN",
                "sum([Soil].Nutrient.MineralisedN) as MineralisedSoilN",
                "sum([Soil].Nutrient.MineralisedNSurfaceResidue) as MineralisedSurfOMN",
                "([Slurp].Leaf.Detached.N+[Slurp].Root.Detached.N)*10.0 as DetachedPlantN",
                "",
                "(sum([Soil].Urea.kgha) + sum([Soil].NH4.kgha) + sum([Soil].NO3.kgha)) as TotalMineralN",
                "sum([Soil].Urea.kgha) as TotalUrea",
                "sum([Soil].NH4.kgha) as TotalNH4",
                "sum([Soil].NO3.kgha) as TotalNO3",
                "[SurfaceOrganicMatter].N as TotalSurfOMN",
                "sum([Soil].Nutrient.FOM.N) as TotalFOMN",
                "sum([Soil].Nutrient.Humic.N) as TotalHumicN",
                "sum([Soil].Nutrient.Microbial.N) as TotalMicrobialN",
                "([Slurp].Leaf.N + [Slurp].Root.N)*10.0 as TotalPlantN",
                "",
                "// Crop outputs",
                "([Slurp].Leaf.Wt + [Slurp].Root.Wt) as TotalPlantWt",
                "//[Slurp].Total.Wt as TotalPlantWt",
                "//([SimpleFruitTree].AboveGroundLive.Wt + [SimpleFruitTree].Root.Live.Wt) as TotalPlantLiveWt",
                "//([SimpleFruitTree].Total.Wt - ([SimpleFruitTree].AboveGroundLive.Wt + [SimpleFruitTree].BelowGroundLive.Wt)) as TotalPlantDeadWt",
                "[Slurp].Leaf.Wt as AboveGroundPlantWt",
                "[Slurp].Root.Wt as BelowGroundPlantWt",
                "[Slurp].Leaf.NConc as AboveGroundNConc",
                "[Slurp].Root.NConc as BelowGroundNConc",
                "[Slurp].Leaf.LAI as LAIGreen",
                "[Slurp].Leaf.LAIDead as LAIDead",
                "[Slurp].Leaf.CoverTotal as CoverTotal",
                "[Slurp].Leaf.Height as CropHeight",
                "[Slurp].Root.Depth as RootDepth",
                "",
                "// Defoliation outputs",
                "//[DefoliationManager].Script.HarvestedWt as DefoliatedWt",
                "",
                "// Other - Extras",
                "[Weather].Radn as RadiationTotal",
                "[MicroClimate].RadiationInterception as RadiationIntercepted",
                "[Weather].MeanT as MeanAirTemperature",
                "[Soil].Temperature.Value[1] as TopSoilTemperature",
                "",
                "//[DefoliationManager].Script.ReturnedWt as DungDepositedWt",
                "[SurfaceOrganicMatter].Wt as TotalSurfaceOMWt",
                "([SurfaceOrganicMatter].C / ([SurfaceOrganicMatter].N + 0.000000001)) as SurfOMCNratio",
                "sum([Soil].Nutrient.FOM.C) / 0.4 as FOMWt",
                "(sum([Soil].Nutrient.FOM.C) / (sum([Soil].Nutrient.FOM.N) + 0.000000001)) as FOMCNratio"
              ],
              "EventNames": [
                "[Clock].DoReport"
              ],
              "GroupByVariableName": null,
              "Name": "BaseReport",
              "ResourceName": null,
              "Children": [],
              "Enabled": true,
              "ReadOnly": false
            },
            {
              "$type": "Models.Report, Models",
              "VariableNames": [
                "[Clock].Today as Date",
                "[Clock].Today",
                "[PlantVariables].Script.Height as height",
                "[PlantVariables].Script.LAI as lai",
                "[PlantVariables].Script.FRadInt as f.rad.int",
                "[PlantVariables].Script.ET as transpiration",
                "[PlantVariables].Script.ES as Es",
                "[PlantVariables].Script.PET as PET",
                "[PlantVariables].Script.RootDepth as rootDepth",
                "[PlantVariables].Script.InterceptedRadiation as IntRadn",
                "[PlantVariables].Script.TotRadn as TotalRadn",
                "[Soil].OutputLayers.SW",
                "sum([Soil].OutputLayers.SWmm) as psw",
                "[Weather].DaysSinceWinterSolstice",
                "[Weather].Rain",
                "[Irrigation].IrrigationApplied",
                "[Soil].SoilWater.Drainage",
                "[Weather].DaysSinceWinterSolstice",
                "[Slurp].Leaf.Transpiration",
                "[Slurp].Leaf.Height",
                "[Slurp].Leaf.CoverGreen",
                "[Slurp].Leaf.LAI",
                "[Slurp].Leaf.WaterDemand",
                "[Slurp].Leaf.Width",
                "[Slurp].Leaf.RadiationIntercepted",
                "[Weather].Radn",
                "[Slurp].Phenology.Stage",
                "[Slurp].Leaf.Wt",
                "[Slurp].Root.Wt",
                "",
                "[Soil].OutputLayers.SW[1] as SWC_0To40",
                "[Soil].OutputLayers.SW[2] as SWC_40To80",
                "[Soil].OutputLayers.SW[3] as SWC_80To120",
                "sum([Soil].OutputLayers.SWmm[1:3]) as SoilWaterProfile"
              ],
              "EventNames": [
                "[Clock].DoReport"
              ],
              "GroupByVariableName": null,
              "Name": "Report",
              "ResourceName": null,
              "Children": [],
              "Enabled": true,
              "ReadOnly": false
            },
