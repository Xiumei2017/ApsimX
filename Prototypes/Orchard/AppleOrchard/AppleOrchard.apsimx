            {
              "$type": "Models.Manager, Models",
              "Code": "using Models.Soils;\r\nusing System;\r\nusing Models.Core;\r\n\r\nnamespace Models\r\n{\r\n    [Serializable]\r\n    public class Script : Model\r\n    {\r\n        \r\n    }\r\n}\r\n",
              "Parameters": [],
              "Name": "PlantVariables",
              "ResourceName": null,
              "Children": [],
              "Enabled": true,
              "ReadOnly": false
            },
            {
              "$type": "Models.Manager, Models",
              "Code": "using Models.Zones;\r\nusing APSIM.Shared.Utilities;\r\nusing Models.Soils;\r\nusing System.Collections.Generic;\r\nusing Models.PMF;\r\nusing Models.Core;\r\nusing System;\r\n\r\nnamespace Models\r\n{\r\n    [Serializable]\r\n    public class Script : Model\r\n    {\r\n        [Link] Clock Clock;\r\n        [Link] Soil soil;\r\n        [Link] Irrigation irrigation;\r\n        [Description(\"Start of sowing window (d-mmm)\")]\r\n        public string StartDate { get; set; }\r\n        [Description(\"End of sowing window (d-mmm)\")]\r\n        public string EndDate { get; set; }\r\n\r\n        [EventSubscribe(\"StartOfDay\")]\r\n        private void OnStartOfDay(object sender, EventArgs e)\r\n        {\r\n        if (DateUtilities.WithinDates(StartDate, Clock.Today, EndDate))\r\n            irrigation.Apply(2, 2500);\r\n        }\r\n    }\r\n}\r\n",
              "Parameters": [
                {
                  "Key": "StartDate",
                  "Value": "1-dec"
                },
                {
                  "Key": "EndDate",
                  "Value": "1-mar"
                }
              ],
              "Name": "WaterTable",
              "ResourceName": null,
              "Children": [],
              "Enabled": true,
              "ReadOnly": false
            },
            {
              "$type": "Models.Manager, Models",
              "Code": "using APSIM.Shared.Utilities;\r\nusing Models.Utilities;\r\nusing Models.Soils;\r\nusing Models.PMF;\r\nusing Models.Core;\r\nusing System;\r\n\r\nnamespace Models\r\n{\r\n    [Serializable]\r\n    public class Script : Model\r\n    {\r\n        [Link] Clock Clock;\r\n        [Link] Plant SimpleFruitTree;\r\n        [Link] Summary Summary;\r\n        [Link] Zone zone;\r\n\r\n        [Description(\"Harvest date (d-mmm)\")]\r\n        public string HarvestDate { get; set; }\r\n        [Description(\"Pruning date (d-mmm)\")]\r\n        public string PruneDate { get; set; }\r\n\r\n        [EventSubscribe(\"DoManagement\")]\r\n        private void OnDoManagement(object sender, EventArgs e)\r\n        {\r\n            if (DateUtilities.WithinDates(HarvestDate, Clock.Today, HarvestDate))\r\n            {\r\n                SimpleFruitTree.RemoveBiomass(\"Harvest\");\r\n                object NotHarvested = 0;\r\n                zone.Set(\"SimpleFruitTree.Fruit.DMDemands.Structural.PartitionFraction.FruitGrowth.Fraction.NotHarvested.FixedValue\", NotHarvested);\r\n            }\r\n\r\n            if (DateUtilities.WithinDates(PruneDate, Clock.Today, PruneDate))\r\n            {\r\n                SimpleFruitTree.RemoveBiomass(\"Prune\");\r\n                object NotHarvested = 1;\r\n                zone.Set(\"SimpleFruitTree.Fruit.DMDemands.Structural.PartitionFraction.FruitGrowth.Fraction.NotHarvested.FixedValue\", NotHarvested);\r\n            }\r\n        }\r\n        \r\n    }\r\n}\r\n",
              "Parameters": [
                {
                  "Key": "HarvestDate",
                  "Value": "15-Apr"
                },
                {
                  "Key": "PruneDate",
                  "Value": "1-Jun"
                }
              ],
              "Name": "HarvestNPrune",
              "ResourceName": null,
              "Children": [],
              "Enabled": true,
              "ReadOnly": false
            }
          ],
          "Enabled": true,
          "ReadOnly": false
