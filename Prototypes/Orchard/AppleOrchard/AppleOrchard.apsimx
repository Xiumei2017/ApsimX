        {
          "$type": "Models.Zones.RectangularZone, Models",
          "Length": 100.0,
          "Width": 1.3,
          "Slope": 0.0,
          "AspectAngle": 0.0,
          "Altitude": 50.0,
          "Name": "Row",
          "ResourceName": null,
          "Children": [
            {
              "$type": "Models.Core.Folder, Models",
              "ShowInDocs": false,
              "GraphsPerPage": 6,
              "Name": "Management",
              "ResourceName": null,
              "Children": [
                {
                  "$type": "Models.Manager, Models",
                  "Code": "\r\nusing Models.Interfaces;\r\nusing Models.Soils;\r\nusing APSIM.Shared.Utilities;\r\nusing Models.PMF;\r\nusing Models.Core;\r\nusing System;\r\nusing Models.PMF.Organs;\r\nusing Models.PMF.Phen;\r\n        \r\nnamespace Models\r\n{\r\n    [Serializable] \r\n    [System.Xml.Serialization.XmlInclude(typeof(Model))]\r\n    public class Script : Model\r\n    {\r\n        [Link] private Zone myZone;\r\n        [Link] private Clock Clock;\r\n        [Link] private Soil Soil;\r\n        [Link] private Plant SimpleFruitTree;\r\n        [Link(Type = LinkType.Path, Path = \"[SimpleFruitTree].Root\")]\r\n        private Root root;\r\n        [Link(Type = LinkType.Path, Path = \"[SimpleFruitTree].Phenology\")]\r\n        private Phenology phenology;\r\n        [Link] private IPhysical soilPhysical;\r\n        [Link] private ISummary summary;\n\r\n        [Display(Type = DisplayType.CultivarName)]\r\n        [Description(\"Tree plant type:\")]\r\n        public string CultivarName { get; set; }\r\n        [Description(\"Initialisation date:\")]\r\n        public DateTime InitialisingDate { get; set; }\r\n        [Description(\"Age of trees (in Years) to initialise:\")]\r\n        public int TreesAge {get;set;}\r\n        [Description(\"Space between rows or trees (mm):\")]\r\n        public double rowSpacing { get; set; }\r\n        [Description(\"Space between trees in a row (mm):\")]\r\n        public double treeSpacing { get; set; }\r\n\r\n        [Description(\"KL in the shallowest layer:\")]\r\n        public double KLAtSurface { get; set; }\r\n        [Description(\"Factor to change KL with depth:\")]\r\n        public double KLReductionFactor { get; set; }\r\n        [Description(\"Depth that KL starts to decline:\")]\r\n        public double KLReductionDepth { get; set; }\r\n        \r\n        public double[] YKLModifiers { get; set; }\r\n        public double[] XDepth { get; set; }\r\n        private double Depth { get; set; }\r\n        \r\n        [EventSubscribe(\"DoManagement\")]\r\n        private void OnDoManagement(object sender, EventArgs e)\r\n        {\r\n            if (Clock.Today.Date == InitialisingDate)\r\n            {\r\n                double maxRootDepth = (double)myZone.Get(\"SimpleFruitTree.Root.MaximumRootDepth.FixedValue\");\n                double totalSoilDepth =  MathUtilities.Sum(soilPhysical.Thickness);\n                double initialRootDepth = Math.Min(Math.Min(1,TreesAge/6) * maxRootDepth, totalSoilDepth);\r\n                SimpleFruitTree.Sow(cultivar: CultivarName, population: 1, depth: initialRootDepth, rowSpacing: 3000);\r\n                object TreesAgeValue = TreesAge;\r\n                myZone.Set(\"SimpleFruitTree.Phenology.Age.Years\",TreesAgeValue);\r\n                YKLModifiers = new double[soilPhysical.Thickness.Length];\r\n                XDepth = new double[soilPhysical.Thickness.Length];\r\n                Depth = 0;\r\n                for (int layer = 0; layer < soilPhysical.Thickness.Length; layer++)\r\n                {\r\n                    Depth += 0.5*soilPhysical.Thickness[layer];  //Add half of the thickness of the current layer so depth is the mid depth of that layer\r\n                    if (Depth <= KLReductionDepth)\r\n                    {\r\n                        YKLModifiers[layer] = KLAtSurface;\r\n                        XDepth[layer] = Depth;\r\n                    }\r\n                    else\r\n                    {\r\n                        double KLMod = KLAtSurface * Math.Exp(-KLReductionFactor * (Depth - KLReductionDepth));\r\n                        YKLModifiers[layer] = KLMod;\r\n                        XDepth[layer] = Depth;\r\n                    }\r\n                    Depth += 0.5*soilPhysical.Thickness[layer];  //Add the other half of the current layer so depth is the top of the next layer\r\n                }\r\n                object KLMods = YKLModifiers;\r\n                myZone.Set(\"SimpleFruitTree.Root.KLModifier.XYPairs.Y\", KLMods);\r\n                object Depths = XDepth;\r\n                myZone.Set(\"SimpleFruitTree.Root.KLModifier.XYPairs.X\", Depths);\r\n            }\r\n        }\r\n    }\r\n}            \r\n",
                  "Parameters": [
                    {
                      "Key": "CultivarName",
                      "Value": "Apple"
                    },
                    {
                      "Key": "InitialisingDate",
                      "Value": "08/01/2021 00:00:00"
                    },
                    {
                      "Key": "TreesAge",
                      "Value": "7"
                    },
                    {
                      "Key": "rowSpacing",
                      "Value": "3000"
                    },
                    {
                      "Key": "treeSpacing",
                      "Value": "2000"
                    },
                    {
                      "Key": "KLAtSurface",
                      "Value": "0.13"
                    },
                    {
                      "Key": "KLReductionFactor",
                      "Value": "0.003"
                    },
                    {
                      "Key": "KLReductionDepth",
                      "Value": "100"
                    }
                  ],
                  "Name": "TreeInitialisation",
                  "ResourceName": null,
                  "Children": [],
                  "Enabled": true,
                  "ReadOnly": false
                },
                {
                  "$type": "Models.Manager, Models",
                  "Code": "using Models.Soils;\r\nusing Models.Functions;\r\nusing APSIM.Shared.Utilities;\r\nusing System.Xml.Serialization;\r\nusing Models;\r\nusing Models.PMF;\r\nusing System.Text;\r\nusing System.Collections.Generic;\r\nusing Models.Core;\r\nusing System;\r\nusing Models.PMF.Organs;\r\n\r\nnamespace Models\r\n{\r\n    [Serializable] \r\n    public class Script : Model\r\n    {\r\n        [Link] private Zone myZone;\r\n        [Link] private Clock Clock;\r\n        [Link(Type = LinkType.Path, Path = \"[SimpleFruitTree].Root\")]\r\n        private Root root;\r\n        [Link] private Plant SimpleFruitTree;\n        [Link] private ISummary summary;\n\r\n        [Description(\"Use extra root myZone\")]\r\n        public bool UseExtraZone { get; set; }\r\n\r\n        \r\n        [EventSubscribe(\"StartOfSimulation\")]\r\n        private void OnSimulationCommencing(object sender, EventArgs e)\r\n        {\r\n            if (UseExtraZone)\r\n            {\r\n                //SimpleFruitTree.Root.ZoneNamesToGrowRootsIn.Add(\"Alley\");\n                root.ZoneNamesToGrowRootsIn.Add(\"Alley\");\r\n                root.ZoneRootDepths.Add(1500);\r\n                NutrientPoolFunctions InitialDM = new NutrientPoolFunctions();\r\n                Constant InitStruct = new Constant();\r\n                InitStruct.FixedValue = 10;\r\n                InitialDM.Structural = InitStruct;\r\n                Constant InitMetab = new Constant();\r\n                InitMetab.FixedValue = 0;\r\n                InitialDM.Metabolic = InitMetab;\r\n                Constant InitStor = new Constant();\r\n                InitStor.FixedValue = 0;\r\n                InitialDM.Storage = InitStor;\r\n                root.ZoneInitialDM.Add(InitialDM);\r\n            }\r\n        }\r\n    }\r\n}\r\n       \r\n\r\n",
                  "Parameters": [
                    {
                      "Key": "UseExtraZone",
                      "Value": "True"
                    }
                  ],
                  "Name": "SetupTreeRootZones",
                  "ResourceName": null,
                  "Children": [],
                  "Enabled": true,
                  "ReadOnly": false
                },
                {
                  "$type": "Models.Manager, Models",
                  "Code": "using Models.Zones;\r\nusing APSIM.Shared.Utilities;\r\nusing Models.Soils;\r\nusing System.Collections.Generic;\r\nusing Models.PMF;\r\nusing Models.Core;\r\nusing System;\r\n\r\nnamespace Models\r\n{\r\n    [Serializable]\r\n    public class Script : Model\r\n    {\r\n        [Link] private Clock clock;\r\n        [Link] private Soil soil;\r\n        [Link] private Irrigation irrigation;\n        [Link] private ISummary summary;\n\r\n        [Description(\"Start of window to simulate high water table (d-mmm)\")]\r\n        public string StartDate { get; set; }\r\n        [Description(\"End of window to simulate high water table (d-mmm)\")]\r\n        public string EndDate { get; set; }\r\n        [Description(\"Depth to simulate high water table (mmm)\")]\r\n        public double TableDepth { get; set; }\r\n\r\n        [EventSubscribe(\"StartOfDay\")]\r\n        private void OnStartOfDay(object sender, EventArgs e)\r\n        {\r\n            if (DateUtilities.WithinDates(StartDate, clock.Today, EndDate))\n            {\n                irrigation.Apply(2, TableDepth);\r\n            }\r\n        }\r\n    }\r\n}\r\n",
                  "Parameters": [
                    {
                      "Key": "StartDate",
                      "Value": "1-Jul"
                    },
                    {
                      "Key": "EndDate",
                      "Value": "1-Jul"
                    },
                    {
                      "Key": "TableDepth",
                      "Value": "1450"
                    }
                  ],
                  "Name": "WaterTable",
                  "ResourceName": null,
                  "Children": [],
                  "Enabled": true,
                  "ReadOnly": false
                },
                {
                  "$type": "Models.Manager, Models",
                  "Code": "using APSIM.Shared.Utilities;\r\nusing Models.Utilities;\r\nusing Models.Soils;\r\nusing Models.PMF;\r\nusing Models.Core;\r\nusing System;\r\n\r\nnamespace Models\r\n{\r\n    [Serializable]\r\n    public class Script : Model\r\n    {\r\n        [Link] private Zone myZone;\r\n        [Link] private Clock clock;\r\n        [Link] private ISummary summary;\n        [Link] private Plant SimpleFruitTree;\r\n \r\n        [Description(\"Harvest date (d-mmm)\")]\r\n        public string HarvestDate { get; set; }\r\n        [Description(\"Pruning date (d-mmm)\")]\r\n        public string PruneDate { get; set; }\r\n\r\n        [EventSubscribe(\"DoManagement\")]\r\n        private void OnDoManagement(object sender, EventArgs e)\r\n        {\r\n            if (DateUtilities.DatesAreEqual(HarvestDate, clock.Today))\r\n            {\r\n                SimpleFruitTree.RemoveBiomass(\"Harvest\");\r\n                object NotHarvested = 0;\r\n                myZone.Set(\"SimpleFruitTree.Fruit.DMDemands.Structural.PartitionFraction.FruitGrowth.Fraction.NotHarvested.FixedValue\", NotHarvested);\r\n            }\r\n\r\n            if (DateUtilities.DatesAreEqual(PruneDate, clock.Today))\r\n            {\r\n                SimpleFruitTree.RemoveBiomass(\"Prune\");\r\n                object NotHarvested = 1;\r\n                myZone.Set(\"SimpleFruitTree.Fruit.DMDemands.Structural.PartitionFraction.FruitGrowth.Fraction.NotHarvested.FixedValue\", NotHarvested);\r\n            }\r\n        }\r\n    }\r\n}\r\n",
                  "Parameters": [
                    {
                      "Key": "HarvestDate",
                      "Value": "15-Apr"
                    },
                    {
                      "Key": "PruneDate",
                      "Value": "1-Jun"
                    }
                  ],
                  "Name": "HarvestNPrune",
                  "ResourceName": null,
                  "Children": [],
                  "Enabled": true,
                  "ReadOnly": false
                },
                {
                  "$type": "Models.Manager, Models",
                  "Code": "// This script will apply irrigation at time and amount determined based on given instructions and/or soil condition\n// Developed by RCichota, last updated in 15/Oct/2022\n\nusing System;\nusing Newtonsoft.Json;\nusing APSIM.Shared.Utilities;\nusing Models.Interfaces;\nusing Models.Core;\nusing Models.PMF;\nusing Models.Soils;\n\nnamespace Models\n{\n    [Serializable]\n    [System.Xml.Serialization.XmlInclude(typeof(Model))]\n    public class Script : Model\n    {\n        //> Links to other Apsim models\n        [Link] private Clock clock;\n        [Link] private IWeather weather;\n        [Link] private Irrigation irrigator;\n        [Link] private IPhysical soilPhysical;\n        [Link] private ISoilWater soilWater;\n        [Link(IsOptional = true)] private IPlant[] existingCrops;\n        [Link] private ISummary summary;\n\n        //> User inputs from properties tab\n        [Separator(\"Generic irrigation management\")]\n        [Description(\" Allow this manager to controll irrigation automatically?\")]\n        public yesNoAnswer AllowAutomaticIrrigation { get; set; }\n        [Description(\" Start of irrigation season (dd-mmm):\")]\n        public string SeasonStartDate { get; set; }\n        [Description(\" End of irrigation season (dd-mmm):\")]\n        public string SeasonEndDate { get; set; }\n\n        [Separator(\"Parameters defining how the irrigation is triggered\")]\n        [Description(\" How irrigation should be triggered?\")]\n        public IrrigationTriggerTypes IrrigationTriggerType { get; set; }\n        [Description(\"   Number of days between irrigations, if using fixed interval:\")]\n        public int IntervalBetweenIrrigations { get; set; }\n        [Description(\"   Deficit to trigger irrigation, if using soil deficit (% PAWC):\")]\n        public double TriggerDeficit { get; set; }\n\n        [Separator(\"Parameters defining how much irrigation is applied\")]\n        [Description(\" How irrigation amount is determined?\")]\n        public IrrigationAmountTypes IrrigationAmountType { get; set; }\n        [Description(\"   Amount of irrigation to apply, if setting amount (mm):\")]\n        public double GivenAmount { get; set; }\n        [Description(\"   Deficit to stop irrigation, if based on soil deficit (% PAWC):\")]\n        public double TargetDeficit { get; set; }\n        [Description(\"   Maximum irrigation application (mm/day):\")]\n        public double MaximumAmount { get; set; }\n\n        [Separator(\"Parameters defining extra constraints to irrigation\")]\n        [Description(\" Limit irrigation to only when there is a crop alive?\")]\n        public yesNoAnswer CheckCropStatus { get; set; }\n        [Description(\" Skip irrigation after significant rainfall?\")]\n        public yesNoAnswer SkipRainDays { get; set; }\n        [Description(\"   Rainfall amount above which irrigation will be stopped (mm/day):\")]\n        public double RainfallThreshold { get; set; }\n        [Description(\"   Minimum number of days between irrigations (ignored if irrigating using fixed interval):\")]\n        public double ReturnDays { get; set; }\n\n        [Separator(\"Parameters for computing soil water status\")]\n        [Description(\" Depth to calculate PAWC and water deficit (mm):\")]\n        public double DepthOfMonitoringLayer { get; set; }\n\n        //> Outputs from this manager\n        [JsonIgnore][Units(\"mm\")] // Soil water deficit in the layer monitored for irrigation\n        public double SoilWaterDeficit { get; set; }\n        [JsonIgnore][Units(\"mm\")] // Soil water content in the layer monitored for irrigation\n        public double MonitoredLayerSWC { get; set; }\n        [JsonIgnore][Units(\"mm\")] // Soil moisute at DUL in the layer monitored for irrigation\n        public double MonitoredLayerDUL { get; set; }\n        [JsonIgnore][Units(\"mm\")] // Soil moisture at LL in the layer monitored for irrigation\n        public double MonitoredLayerLL { get; set; }\n        [JsonIgnore][Units(\"days\")] // Number of days since last irrigation\n        public double DaysSinceIrrigation { get; set; }\n        [JsonIgnore][Units(\"mm\")] // Amount of water to apply in a given irrigation event\n        public double AmountToApply { get; set; }\n        [JsonIgnore][Units(\"mm\")] // Total amount of water applied over the irrigation season\n        public double SeasonAppliedAmount { get; set; }\n\n        //> Internal variables\n        private int bottomLayer;\n        private double fracBottomLayer;\n        private bool seasonIsOpen;\n        private bool cropIsActive;\n        private bool rainIsNotSignificant;\n        private bool irrigatorIsAvailable;\n        private bool soilMoistureIsLow;\n\n\n        [EventSubscribe(\"StartOfSimulation\")]\n        private void OnStartOfSimulation(object sender, EventArgs e)\n        {\n            // check whether irrigation is allowed at all\n            if (AllowAutomaticIrrigation == yesNoAnswer.Yes)\n            {\n                // check whether we need to check crop status\n                if (CheckCropStatus == yesNoAnswer.Yes)\n                {\n                    if(existingCrops == null)\n                    {\n                        throw new Exception(\" Manager requires checking active crop, but no crop is present\");\n                    }\n                }\n            }\n\n            //Calculate soil water variables\n            double depthFromSurface = 0.0;\n            for (int layer = 0; layer < soilPhysical.Thickness.Length; layer++)\n            {\n                fracBottomLayer = Math.Min(1.0, (DepthOfMonitoringLayer - depthFromSurface) / soilPhysical.Thickness[layer]);\n                MonitoredLayerLL += soilPhysical.LL15mm[layer] * fracBottomLayer;\n                MonitoredLayerDUL += soilPhysical.DULmm[layer] * fracBottomLayer;\n                depthFromSurface += soilPhysical.Thickness[layer];\n                if (depthFromSurface >= DepthOfMonitoringLayer)\n                {\n                    bottomLayer = layer;\n                    layer = soilPhysical.Thickness.Length;\n                }\n            }\n\n            // write message in summary\n            summary.WriteMessage(this,\" Automatic irrigation manager initialised\", MessageType.Diagnostic);\n            if (AllowAutomaticIrrigation == yesNoAnswer.Yes)\n            {\n                summary.WriteMessage(this,\"  Irrigation is enabled between \" + SeasonStartDate + \" and \" + SeasonEndDate, MessageType.Diagnostic);\n                if (IrrigationTriggerType == IrrigationTriggerTypes.FixedInterval)\n                {\n                    summary.WriteMessage(this,\"  Irrigation will be triggered every \" + IntervalBetweenIrrigations + \" days\", MessageType.Diagnostic);\n                }\n                else\n                {\n                    summary.WriteMessage(this,\"  Irrigation will be triggered every time soil moisture is below \" + TriggerDeficit.ToString(\"#0.0\") + \"% of PAWC\", MessageType.Diagnostic);\n                }\n\n                if (IrrigationAmountType == IrrigationAmountTypes.GivenAmount)\n                {\n                    summary.WriteMessage(this,\"  Amount to be applied is fixed at \" + Math.Min(MaximumAmount, GivenAmount).ToString(\"#0.0\") + \"mm each application\", MessageType.Diagnostic);\n                }\n                else\n                {\n                    summary.WriteMessage(this,\"  Amount to be applied will aim to bring soil moisture up to \" + TargetDeficit.ToString(\"#0.0\") + \"% of PAWC\", MessageType.Diagnostic);\n                    summary.WriteMessage(this,\"   limited to \" + MaximumAmount.ToString(\"#0.0\") + \"mm in each application\", MessageType.Diagnostic);\n                }\n            }\n            else\n            {\n                summary.WriteMessage(this,\"  Irrigation is disabled\", MessageType.Diagnostic);\n            }\n        }\n\n        [EventSubscribe(\"StartOfDay\")]\n        private void OnStartOfDay(object sender, EventArgs e)\n        {\n            // check whether we are within the irrigation season\n            if(DateUtilities.WithinDates(SeasonStartDate, clock.Today, SeasonEndDate))\n            {\n                seasonIsOpen = true;\n            }\n            else\n            {\n                seasonIsOpen = false;\n                SeasonAppliedAmount = 0;\n            }\n\n            // check for whether there is a crop that needs irrigation\n            if (CheckCropStatus == yesNoAnswer.Yes)\n            {\n                cropIsActive = false;\n                foreach (IPlant crop in existingCrops)\n                {\n                    if (crop.IsAlive)\n                    {\n                        cropIsActive = true;\n                        break;\n                    }\n                }\n            }\n            else\n            {\n                cropIsActive = true;\n            }\n\n            // check whether there has been significant rainfall\n            rainIsNotSignificant = true;\n            if (SkipRainDays == yesNoAnswer.Yes && weather.Rain > RainfallThreshold)\n            {\n                rainIsNotSignificant = false;\n            }\n\n            // check whether the irrigator available\n            irrigatorIsAvailable = false;\n            DaysSinceIrrigation += 1;\n            if(IrrigationTriggerType == IrrigationTriggerTypes.FixedInterval)\n            {\n                if (DaysSinceIrrigation >= IntervalBetweenIrrigations)\n                {\n                    irrigatorIsAvailable = true;\n                }\n            }\n            else\n            {\n                if (DaysSinceIrrigation >= ReturnDays)\n                {\n                    irrigatorIsAvailable = true;\n                }\n            }\n        }\n\n        [EventSubscribe(\"DoManagement\")]\n        private void OnDoManagement(object sender, EventArgs e)\n        {\n            // get current soil moisture and water deficit\n            MonitoredLayerSWC = 0.0;\n            for (int layer = 0; layer < bottomLayer; layer++)\n            {\n                MonitoredLayerSWC += soilWater.SWmm[layer];\n            }\n\n            MonitoredLayerSWC += soilWater.SWmm[bottomLayer] * fracBottomLayer;\n            SoilWaterDeficit = MonitoredLayerSWC - MonitoredLayerDUL;\n\n            if (AllowAutomaticIrrigation == yesNoAnswer.Yes)\n            {\n                // check whether the soil is dry enough to require irrigation\n                if(IrrigationTriggerType == IrrigationTriggerTypes.TriggerBySoilDeficit)\n                {\n                    soilMoistureIsLow = false;\n                    if (Math.Max(0.0, -SoilWaterDeficit) >= (MonitoredLayerDUL - MonitoredLayerLL) * (100.0 - TriggerDeficit) / 100.0)\n                    {\n                        soilMoistureIsLow = true;\n                    }\n                }\n                else\n                { // moisture is not checked\n                    soilMoistureIsLow = true;\n                }\n\n                // check whether all the conditions ratify irrigation\n                if (seasonIsOpen && cropIsActive && irrigatorIsAvailable && rainIsNotSignificant && soilMoistureIsLow)\n                {\n                    // let's bloody well irrigate then!!!!\n                    if(IrrigationAmountType == IrrigationAmountTypes.GivenAmount)\n                    {\n                        AmountToApply = Math.Min(GivenAmount, MaximumAmount);\n                    }\n                    else\n                    {\n                        AmountToApply = MonitoredLayerLL + (MonitoredLayerDUL - MonitoredLayerLL) * TargetDeficit / 100.0 - MonitoredLayerSWC;\n                        AmountToApply = Math.Max(0.0, Math.Min(AmountToApply, MaximumAmount));\n                    }\n    \n                    irrigator.Apply(amount: AmountToApply, depth: 0.0, duration: 1440, willRunoff: true);\n                    DaysSinceIrrigation = 0;\n                    SeasonAppliedAmount += AmountToApply;\n                }\n            }\n        }\n\n\n        /// <summary>Flag for a positive or negative answer</summary>\n        public enum yesNoAnswer\n        {\n            /// <summary>Positive answer</summary>\n            Yes,\n            /// <summary>Negative answer</summary>\n            No\n        }\n\n        /// <summary>Flag how irrigation will be triggered</summary>\n        public enum IrrigationTriggerTypes\n        {\n            /// <summary>Setting a fixed interval</summary>\n            FixedInterval,\n            /// <summary>Setting a soil deficit</summary>\n            TriggerBySoilDeficit\n        }\n\n        /// <summary>Flag how much irrigation will be applied</summary>\n        public enum IrrigationAmountTypes\n        {\n            /// <summary>Setting a fixed interval</summary>\n            GivenAmount,\n            /// <summary>Setting a soil deficit</summary>\n            BasedOnSoilDeficit\n        }\n    }\n}\n",
                  "Parameters": [
                    {
                      "Key": "AllowAutomaticIrrigation",
                      "Value": "Yes"
                    },
                    {
                      "Key": "SeasonStartDate",
                      "Value": "20-Dec"
                    },
                    {
                      "Key": "SeasonEndDate",
                      "Value": "05-Feb"
                    },
                    {
                      "Key": "IrrigationTriggerType",
                      "Value": "TriggerBySoilDeficit"
                    },
                    {
                      "Key": "IntervalBetweenIrrigations",
                      "Value": "0"
                    },
