                },
                {
                  "$type": "Models.Report, Models",
                  "VariableNames": [
                    "[Clock].Today",
                    "sum of [Soil].SoilWater.Flux[7] from 2008-10-01 to 2010-07-23 as drainage"
                  ],
                  "EventNames": [
                    "[Clock].DoReport"
                  ],
                  "GroupByVariableName": null,
